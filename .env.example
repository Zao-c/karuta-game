# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only. Do not expose this in client-side runtime variables.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional public site URL after deployment
NEXT_PUBLIC_APP_URL=https://your-project-name.vercel.app
